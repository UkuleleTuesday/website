# Copy this file to .env and fill in your values for local development with Netlify Dev.
# Ask a team member for the actual secret values.
# Never commit the .env file to source control.

# Required for the Events Calendar (Netlify function: netlify/functions/calendar.js)
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here

# Required for the WhatsApp gate (Netlify function: netlify/functions/whatsapp-gate.js)
WHATSAPP_JOIN_LINK=https://chat.whatsapp.com/your_invite_link_here

# Optional: Buy Me A Coffee redirect URL (defaults shown below)
BMC_URL=https://buymeacoffee.com/ukuleletuesday
BMC_DEFAULT_UTMS=utm_source=screen&utm_medium=qr&utm_campaign=donate
